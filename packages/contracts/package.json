    "./screens": "./src/screens.ts",
    "./sdk": "./src/sdk.ts",
    "./sdkAttributes": "./src/sdkAttributes.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "node ../../scripts/build-publishable-package.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
